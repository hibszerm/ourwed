# Supabase (required)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Document AI — production uses Edge Function `document-ai-analysis` + GEMINI_API_KEY
# (Supabase Secrets only; never put Gemini keys in Vite).
# Optional: force mock analyzer for offline UI work
# VITE_DOCUMENT_AI_USE_MOCK=true

# Geoapify (travel / geocoding)
VITE_GEOAPIFY_API_KEY=your-geoapify-key
