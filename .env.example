# Supabase (required)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Document AI — production uses Edge Function `document-ai-analysis` + OPENAI_API_KEY
# (Supabase Secrets only; never put OpenAI keys in Vite).
# Optional: force mock analyzer for offline UI work
# VITE_DOCUMENT_AI_USE_MOCK=true
# Dev-only: dual-pass extraction diagnostic (Pass 1 business understanding + Pass 2 production)
# Runs two AI calls per analysis. Never enabled in production builds.
# VITE_DOCUMENT_AI_DIAGNOSTIC=true

# Geoapify (travel / geocoding)
VITE_GEOAPIFY_API_KEY=your-geoapify-key
